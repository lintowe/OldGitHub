{
  "name": "old-github",
  "version": "1.0.0",
  "private": true,
  "description": "Restore the 2012-2013 GitHub layout as a Chrome extension.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:icons": "node scripts/build-icons.mjs",
    "build:ext-icons": "node scripts/build-extension-icons.mjs",
    "prebuild": "npm run build:icons && npm run build:ext-icons",
    "predev": "npm run build:icons && npm run build:ext-icons",
    "pretypecheck": "npm run build:icons",
    "dev": "node scripts/run-dev.mjs",
    "dev:build": "vite build --watch --mode development",
    "dev:reload": "node scripts/dev-reload.mjs",
    "build": "vite build",
    "pack": "npm run build && node scripts/pack.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "highlight.js": "11.11.1",
    "octicons": "8.5.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@samrum/vite-plugin-web-extension": "5.1.1",
    "@types/chrome": "^0.0.270",
    "typescript": "5.4.5",
    "vite": "5.4.21"
  }
}
